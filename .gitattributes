# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly mark known text files
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.json text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.dockerignore text eol=lf
